# ---- Server ----
# API binds to localhost; HAProxy terminates TLS and forwards here.
HTTP_ADDR=127.0.0.1:8080
# Public base URL the API is reachable at (used to build OAuth callback URLs).
PUBLIC_BASE_URL=https://license.arib.example

# ---- MongoDB (Atlas) ----
MONGO_DB=arib_license
MONGO_USER=arib
MONGO_PASS=secret
MONGO_URI=mongodb://${MONGO_USER}:${MONGO_PASS}@mongodb:27017/${MONGO_DB}?authSource=admin

# ---- Signing key (.NET RSAKeyValue XML, same keypair as the POS public key) ----
# Either a path to the XML file, or the XML inline (PRIVATE_KEY_XML wins if set).
PRIVATE_KEY_XML_PATH=keys/PrivateKey.xml
# PRIVATE_KEY_XML=<RSAKeyValue>...</RSAKeyValue>

# ---- Session JWT ----
# 32+ byte random secret for signing app session (access) tokens.
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL=720h

# ---- Sync gateway / shard registry ----
# URL of the single sync gateway (used as the fallback when SYNC_SHARDS is unset).
# In multi-shard deployments this is ignored in favour of SYNC_SHARDS.
SYNC_GATEWAY_URL=http://127.0.0.1:5310

# Multi-shard registry: semicolon-separated list of shard_id=gateway_url pairs.
# Each gateway must be started with SHARD_ID matching its entry here.
# When unset, a single "shd_default" shard is synthesised from SYNC_GATEWAY_URL.
# Example (two shards):
#   SYNC_SHARDS=shd_a=http://gw-a:5310;shd_b=http://gw-b:5310
SYNC_SHARDS=

# ---- License clocks ----
REVALIDATE_AFTER=336h   # 14 days  -> token.revalidateBy
HARD_EXPIRE_AFTER=672h  # 28 days  -> token.hardExpiry
TRIAL_DURATION=168h     # 7 days
RELEASE_COOLDOWN=72h    # min time between self-service releases of the same device
RELEASE_MAX_PER_MONTH=3

# ---- Email (OTP delivery via SMTP) ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=change-me
SMTP_FROM=Arib POS <no-reply@arib.example>
OTP_TTL=10m
OTP_MAX_ATTEMPTS=5

# ---- OAuth: Google ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- OAuth: Facebook ----
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ---- Admin bootstrap ----
# Comma-separated emails allowed to use the admin dashboard/endpoints.
ADMIN_EMAILS=you@arib.example

# ---- Admin dashboard (CORS) ----
# Comma-separated browser origins allowed to call the API (the admin dashboard).
# Leave empty to disable CORS. Include the Vite dev origin for local development.
DASHBOARD_ORIGINS=https://admin.arib.example,http://localhost:5173
